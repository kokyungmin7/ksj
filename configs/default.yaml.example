model:
  qwen_name: "Qwen/Qwen3-VL-8B-Instruct"
  dino_name: "facebook/dinov3-vits16-pretrain-lvd1689m"
  torch_dtype: "bfloat16"
  attn_implementation: "flash_attention_2"  # "eager" if flash_attn not installed
  device: "cuda"  # device_map for evaluation; "cuda" or "cuda:0"

data:
  csv_path: "train.csv"
  image_root: "."
  val_split: 0.2
  seed: 42
  subset: null  # int: use only N samples (stratified); null: use all

lora:
  r: 16
  lora_alpha: 32
  lora_dropout: 0.05
  bias: "none"
  target_modules:
    - "q_proj"
    - "k_proj"
    - "v_proj"
    - "o_proj"
    - "gate_proj"
    - "up_proj"
    - "down_proj"

training:
  output_dir: "outputs/qwen3vl-lora"
  num_train_epochs: 3
  per_device_train_batch_size: 2
  gradient_accumulation_steps: 8
  learning_rate: 2.0e-4
  lr_scheduler_type: "cosine"
  warmup_ratio: 0.05
  weight_decay: 0.01
  logging_steps: 10
  save_steps: 200
  save_total_limit: 2
  bf16: true
  gradient_checkpointing: true
  max_seq_length: 1024
  remove_unused_columns: false
  f1_eval_samples: 200          # epoch마다 F1 측정에 사용할 val 샘플 수

evaluation:
  output_dir: "results"
  max_new_tokens: 5

dino:
  enabled: true                                    # false: detector not loaded; Qwen uses original image only
  model_name: "IDEA-Research/grounding-dino-tiny"  # or grounding-dino-base for higher accuracy
  box_threshold: 0.25          # detection confidence threshold
  text_threshold: 0.20         # text-image matching threshold
  crop_padding: 20             # pixels of padding around union bbox
  crop_min_size: 64            # minimum crop size; fallback to full image if smaller

visualization:
  enabled: true
  output_dir: "results/viz"
  save_every: 1               # save visualization every N samples (1 = all)
  max_samples: null           # maximum number of visualizations to save (null = all)
  dpi: 150
